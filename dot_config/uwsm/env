
### Toolkit Backend Variables ###
export GDK_BACKEND='wayland,x11,*'
export QT_QPA_PLATFORM='wayland;xcb'
export CLUTTER_BACKEND='wayland'

#Run SDL2 applications on Wayland.
#Remove or set to x11 if games that provide older versions of SDL cause compatibility issues
# export SDL_VIDEODRIVER='wayland'

### XDG Specifications ###
export XDG_CURRENT_DESKTOP='Hyprland'
export XDG_SESSION_DESKTOP='Hyprland'
export XDG_SESSION_TYPE='wayland'

### QT Variables ###
export QT_AUTO_SCREEN_SCALE_FACTOR='1'
export QT_WAYLAND_DISABLE_WINDOWDECORATION='1'
export QT_QPA_PLATFORMTHEME='qt5ct'
export QT_QPA_PLATFORMTHEME='qt6ct'

### hyprland-qt-support ###
export QT_QUICK_CONTROLS_STYLE='org.hyprland.style'

### xwayland apps scale fix (useful if you are use monitor scaling) ###
# Set same value if you use scaling in Monitors.conf
# 1 is 100% 1.5 is 150%
# see https://wiki.hyprland.org/Configuring/XWayland/
export GDK_SCALE='1'
export QT_SCALE_FACTOR='1'

# Bibata-Modern-Ice-Cursor
# NOTE! You must have the hyprcursor version to activate this.
# https://wiki.hyprland.org/Hypr-Ecosystem/hyprcursor/
# export HYPRCURSOR_THEME='Adwaita'
# export HYPRCURSOR_SIZE='24'
export XCURSOR_THEME='Adwaita'
export XCURSOR_SIZE='24'

### firefox ###
export MOZ_ENABLE_WAYLAND='1'

### electron >28 apps (may help) ###
# https://www.electronjs.org/docs/latest/api/environment-variables
# auto selects Wayland if possible, X11 otherwise
export ELECTRON_OZONE_PLATFORM_HINT='auto'

### NVIDIA ###
# This is from Hyprland Wiki. Below will be activated nvidia gpu detected
# See hyprland wiki https://wiki.hyprland.org/Nvidia/#environment-variables

export LIBVA_DRIVER_NAME='nvidia'
export __GLX_VENDOR_LIBRARY_NAME='nvidia'
export NVD_BACKEND='direct'
export GSK_RENDERER='ngl'

